# Build instructions for the BigWigs packager (run by the release workflow).
# https://github.com/BigWigsMods/packager
package-as: OppositeQOL

# This addon bundles no external libraries, so skip the separate "-nolib" zip.
enable-nolib-creation: no

# Kept in the repo for development, but excluded from the packaged addon.
# (No inline comments on the list entries -- the packager treats them as part of
# the path, which is why an earlier "- tools  # ..." failed to match.)
ignore:
  - README.md
  - tests
  - tools
  - .github
  - .gitignore
  - .gitattributes
  - .editorconfig
